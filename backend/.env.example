# ─── Application ─────────────────────────────────────────────────────────────
ENV=development
DEBUG=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./ai_recruiter.db
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/ai_recruiter

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_jwt_secret_here
JWT_EXPIRE_MINUTES=1440

# ─── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=claude

# Replace with your own Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model name
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional if using OpenAI
OPENAI_API_KEY=

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# ─── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_INDEX_DIR=./vector_index
EMBEDDING_DIM=256

# ─── GitHub Enrichment (optional) ────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Trust Engine ─────────────────────────────────────────────────────────────
TRUST_HIGH_RISK_THRESHOLD=55
